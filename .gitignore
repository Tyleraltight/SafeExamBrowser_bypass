pip/

# Compiled binaries (keep only source + bin/final)
bin/*
!bin/final/

# .NET build artifacts
seb-patcher/bin/
seb-patcher/obj/
display-patcher/bin/
display-patcher/obj/
il-patcher/

# Third-party tools (download separately)
tools/dnSpy/
tools/dnSpy.zip

# SEB installer (too large)
seb-layout/

# Extracted temp files
seb-extract/
seb-extract2/

# Test files
test-patch/

# Logs and reports (contain sensitive info)
vm_logs/
*.log
report.json

# VC++ files (can extract from host system)
vcpp-files/

